model User {
  id         String     @id @default(uuid())
  name       String     @db.VarChar(255)
  email      String     @unique
  password   String
  role       Role
  userStatus UserStatus @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  profile    Profile?

  properties     Property[]
  rentalRequests RentalRequest[]
  payments       Payment[]
  reviews        Review[]
}
